{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Essence PowerPoint",
  "version": "0.1.0",
  "identifier": "app.essence.powerpoint",
  "build": {
    "frontendDist": "https://essence-powerpoint.vercel.app",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Essence PowerPoint",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["essdeck"],
        "name": "Essence Deck",
        "description": "Essence PowerPoint deck",
        "role": "Editor",
        "rank": "Owner",
        "mimeType": "application/vnd.essence.powerpoint.deck+json",
        "exportedType": {
          "identifier": "app.essence.powerpoint.deck",
          "conformsTo": ["public.json", "public.data"]
        }
      }
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
